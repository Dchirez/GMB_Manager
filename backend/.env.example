# Google OAuth 2.0 Configuration
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://gmb-backend.dchirez.fr/auth/callback

# Flask Configuration
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/gmb_manager

# Frontend URL
FRONTEND_URL=https://gmb.dchirez.fr

# Supabase Configuration (for photo storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Database Reset (set to 'true' to drop and recreate all tables on startup)
RESET_DB=false
